---
import '@/components/atoms/FloatingLeaves/FloatingLeaves.css'

const LEAF_COUNT = 14
---

<div class="floating-leaves" aria-hidden="true">
    {Array.from({ length: LEAF_COUNT }).map(() => (
        <div class="floating-leaves__leaf">
            <div class="floating-leaves__leaf-flutter">
                <svg class="floating-leaves__leaf-svg" viewBox="0 0 24 24">
                    <path class="floating-leaves__leaf-body" d="M12 2C6 8 4 14 12 22C20 14 18 8 12 2Z" />
                    <path class="floating-leaves__leaf-vein" d="M12 4C12 9 12 15 12 20" />
                    <path class="floating-leaves__leaf-vein" d="M12 8C10.5 8.6 9.3 9.8 8.3 11.3" />
                    <path class="floating-leaves__leaf-vein" d="M12 8C13.5 8.6 14.7 9.8 15.7 11.3" />
                    <path class="floating-leaves__leaf-vein" d="M12 13C10.3 13.7 9 15 8 16.8" />
                    <path class="floating-leaves__leaf-vein" d="M12 13C13.7 13.7 15 15 16 16.8" />
                </svg>
            </div>
        </div>
    ))}
</div>
